# 后端环境变量示例,复制为 .env 后按需填写
# 启动后端前通过环境变量或 IDE Run Config 注入

# 数据库
DB_USERNAME=postgres
DB_PASSWORD=123456

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=creditpass
MINIO_REGION=cn-beijing-1
MINIO_SECURE=false
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# 阿里云邮件推送(注意:不要提交到 Git)
ALIYUN_MAIL_API_KEY=
ALIYUN_MAIL_SECRET_KEY=
ALIYUN_MAIL_SENDER_EMAIL=aitest@mail.pantoria.cn
ALIYUN_MAIL_REGION_ID=cn-hangzhou
